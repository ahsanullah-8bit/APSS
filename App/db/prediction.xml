      <column name="frameId" type="TEXT" null="true"/>
      <column name="videoTimestamp" type="TEXT" null="true"/>
      <column name="streamTimestamp" type="TEXT" null="true"/>
      <column name="data" type="TEXT" null="true"/>
      <primary-key auto="true">
        <column name="id"/>
      </primary-key>
    </table>
  </model>
</changelog>
